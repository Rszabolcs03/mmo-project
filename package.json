{
  "name": "mmo-project",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:server": "node --watch server/index.js",
    "start": "node server/index.js",
    "start:server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "electron": "npm run build && electron .",
    "electron:pack": "npm run build && set ELECTRON_BUILDER_CACHE=.cache\\electron-builder&& electron-builder --dir",
    "electron:dist": "npm run build && set ELECTRON_BUILDER_CACHE=.cache\\electron-builder&& electron-builder",
    "update:prepare": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts\\prepare-update.ps1"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "@colyseus/schema": "^4.0.25",
    "@colyseus/sdk": "^0.17.42",
    "@vitejs/plugin-react": "latest",
    "colyseus": "^0.17.10",
    "firebase": "^12.13.0",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.mmo.project",
    "productName": "Top-Down MMO Prototype",
    "npmRebuild": false,
    "electronDownload": {
      "cache": ".cache/electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
